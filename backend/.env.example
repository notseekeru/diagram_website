PORT = 5050

# Number of reverse proxies in front of Express (nginx + LB).
# Set to 0 if no proxy, 1 for single proxy, 2+ for chain.
TRUST_PROXY_HOPS = 0

DATABASE_URL=postgres://diagram:diagram@postgres:5432/diagramdb

API_KEY=replace-with-a-secure-key

# Comma-separated origins allowed by CORS.
# Overrides defaultOrigins in server.ts.
# Include all domains the frontend is served from.
FRONTEND_ORIGINS=http://localhost:5223,https://diagram.seekeru.tech

# OpenTelemetry — <...>_TRACES_ENDPOINT and <...>_METRICS_ENDPOINT are read by instrumentation.ts
# The SDK reads OTEL_SERVICE_NAME, OTEL_EXPORTER_OTLP_PROTOCOL, OTEL_SEMCONV_STABILITY_OPT_IN
# from env automatically; only overrides needed here.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://alloy:4318/v1/metrics
OTEL_METRIC_EXPORT_INTERVAL=10000
NODE_ENV=chaos
