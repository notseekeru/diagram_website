PORT = 5000 # Also change in frontend .env
TRUST_PROXY_HOPS = trust-proxy-hops-here
DATABASE_URL=postgres://diagram:diagram@postgres:5432/diagramdb
API_KEY=replace-with-a-secure-key
FRONTEND_ORIGINS=http://localhost:5173
OTEL_SERVICE_NAME=diagram_backend_app
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://alloy:4318/v1/metrics
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SEMCONV_STABILITY_OPT_IN=http
OTEL_METRIC_EXPORT_INTERVAL=10000
OTEL_LOG_LEVEL=debug # Set to debug for development, change to info or error in production, and note to change in the compose file alloy service and alloy configuration as well.
NODE_ENV=chaos